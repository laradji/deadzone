# /artifacts/ holds per-lib subdirectories (one per lib_id slug, each
# containing artifact.db + state.yaml + transient WAL/SHM files). The
# whole folder shape is disposable build output; only the committed
# artifacts/manifest.yaml stays tracked as the release-history trace
# (see #101). The directory glob matches every subdir at the top level,
# which is exactly the shape the scraper produces.
/artifacts/*/
# libtokenizers.a and friends land here via `just fetch-tokenizers`;
# it's a dev artifact directory, never tracked.
/lib/
/.envrc
.DS_Store
.mcp.json
CLAUDE.md
.claude/
.emdash.json
